# Lightpanda CDP
LP_CDP_URL=ws://lightpanda:9222

# PinchTab HTTP API
PINCHTAB_BASE_URL=
PINCHTAB_MCP_ENDPOINT=/mcp
PINCHTAB_TOKEN=

# OpenCLI 配置
OPENCLI_BIN=opencli
OPENCLI_TIMEOUT_SECONDS=30
OPENCLI_ALLOWLIST_JSON={"bilibili":"hot","zhihu":"trending","hackernews":"top","reddit":"hot"}

# Research 流水线开关
RESEARCH_OPENCLI_ENABLED=true
RESEARCH_OPENCLI_FALLBACK=true
RESEARCH_PREFERRED_TOOL_ORDER=opencli,scrapling

# Scrapling 超时 & 重试
SCRAPLING_TIMEOUT=30
MAX_PROXY_RETRIES=3

# MCP 服务器
MCP_HOST=0.0.0.0
MCP_PORT=8000
